<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="backend.modules.profile.mapper.ProfileMapper">

    <!--
        查询 v_volunteer_profile 视图
        map-underscore-to-camel-case=true 自动处理字段映射：
          user_id          → userId
          real_name        → realName
          student_id       → studentId
          avatar_url       → avatarUrl
          total_hours      → totalHours
          activity_count   → activityCount
          type_diversity   → typeDiversity
          avg_score        → avgScore
          punctuality_rate → punctualityRate
          badge_count      → badgeCount
          skill_tags       → skillTags
    -->
    <select id="selectByUserId" resultType="backend.modules.profile.dto.ProfileVO">
        SELECT user_id,
               real_name,
               student_id,
               avatar_url,
               total_hours,
               activity_count,
               type_diversity,
               avg_score,
               punctuality_rate,
               badge_count,
               skill_tags
        FROM v_volunteer_profile
        WHERE user_id = #{userId}
    </select>

</mapper>
